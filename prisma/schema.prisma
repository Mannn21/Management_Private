generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Siswa {
  id           Int      @id @default(autoincrement())
  nama         String
  usia         Int
  jenisKelamin String
  alamat       String
  jenjang      String
  sekolah      String?
  namaOrtu     String?
  noHp         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  jadwal       Jadwal[]
  catatan      Catatan[]
}

model Jadwal {
  id           Int      @id @default(autoincrement())
  siswaId      Int
  siswa        Siswa    @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  hari         String
  jamMulai     String
  jamSelesai   String
  mapel        String
  status       String   @default("Terjadwal")
  catatan      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Catatan {
  id          Int       @id @default(autoincrement())
  siswaId     Int       
  siswa       Siswa     @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  tanggal     DateTime
  materi      String
  pemahaman   String    @default("Cukup")
  pr          String?
  catatan     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}