generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Siswa {
  id           Int      @id @default(autoincrement())
  nama         String
  usia         Int
  jenisKelamin String
  alamat       String
  jenjang      String
  sekolah      String?
  namaOrtu     String?
  noHp         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  jadwal       Jadwal[]
}

model Jadwal {
  id           Int      @id @default(autoincrement())
  siswaId      Int
  siswa        Siswa    @relation(fields: [siswaId], references: [id], onDelete: Cascade)
  hari         String
  jamMulai     String
  jamSelesai   String
  mapel        String
  status       String   @default("Terjadwal")
  catatan      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

